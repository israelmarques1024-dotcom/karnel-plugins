{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/israelmarques1024-dotcom/karnel-plugins/blob/main/schemas/karnel-plugin.schema.json",
  "title": "Karnel plugin manifest",
  "description": "Schema v1 for karnel-plugin.json. Bash plugins are trusted code, not sandboxed extensions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "version",
    "description",
    "commands",
    "minKarnelVersion",
    "license"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,62}$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-((0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(\\.(0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(\\+([0-9A-Za-z-]+)(\\.[0-9A-Za-z-]+)*)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]{0,62}$"
      }
    },
    "minKarnelVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-((0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(\\.(0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(\\+([0-9A-Za-z-]+)(\\.[0-9A-Za-z-]+)*)?$"
    },
    "license": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]{0,63}$"
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": [
          "network",
          "filesystem-read",
          "filesystem-write",
          "process",
          "environment"
        ]
      }
    }
  }
}
