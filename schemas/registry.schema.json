{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/israelmarques1024-dotcom/karnel-plugins/blob/main/schemas/registry.schema.json",
  "title": "Karnel approved plugin registry",
  "description": "Schema v1 for the Karnel Termux approved plugin registry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "description",
    "plugins"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-((0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(\\.(0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(\\+([0-9A-Za-z-]+)(\\.[0-9A-Za-z-]+)*)?$"
    },
    "command": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,62}$"
    },
    "capability": {
      "enum": [
        "network",
        "filesystem-read",
        "filesystem-write",
        "process",
        "environment"
      ]
    },
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "repo",
        "ref",
        "version",
        "description",
        "commands",
        "minKarnelVersion",
        "license",
        "checksum"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/command"
        },
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,38}/[A-Za-z0-9][A-Za-z0-9._-]{0,99}$",
          "not": {
            "pattern": "(\\.\\.|\\.git$)"
          }
        },
        "ref": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,127}$",
          "not": {
            "pattern": "(\\.\\.|//|/$)"
          }
        },
        "path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,127}$",
          "not": {
            "pattern": "(^\\.git|\\.\\.|//|/$)"
          }
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "minKarnelVersion": {
          "$ref": "#/$defs/semver"
        },
        "license": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]{0,63}$"
        },
        "checksum": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/capability"
          }
        }
      }
    }
  }
}
